#pragma endian big

#pragma array_limit 10000000
#pragma pattern_limit 10000000

#include <std/mem.pat>

// Defines a single ITCH Message Block
struct MessageBlock {
    u16 message_length;
    
    // Safety check: only parse if the length is valid
    if (message_length > 0) {
        // The first byte of an ITCH message is always the Message Type (e.g., 'S', 'A')
        char message_type;
        // The rest of the payload belongs to the ITCH message
        u8 message_data[message_length - 1];
    }
};

// Defines the MoldUDP64 transport wrapper
struct MoldUDP64Packet {
    char session[10];
    u64 sequence_number;
    u16 message_count;
    
    // Parse the exact number of ITCH messages defined in the MoldUDP header
    if (message_count > 0) {
        MessageBlock messages[message_count];
    }
};

// Dynamically parse packets starting from offset 0x00 until the end of the file is reached
MoldUDP64Packet packets[while(!std::mem::eof())] @ 0x00;